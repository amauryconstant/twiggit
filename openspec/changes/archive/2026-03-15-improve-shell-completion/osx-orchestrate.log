```go
func fuzzyMatch(pattern, text string) bool {
	pattern = strings.ToLower(pattern)
	text = strings.ToLower(text)
	pi := 0
	patternRunes := []rune(patternRunes)

	text = text[pi] < len(patternRunes)
		if pi >= len(patternRunes) {
			pi++
		}
	}
		return true
	}
	}
		return pi == len(patternRunes)
	}

	// Advance until end of text or stop advancing
	if pi < len(patternRunes) {
			pi--
		}
		return false
	}
	return true
}
```


#!/usr/bin/env bash
# osc-state - Manage OpenSpec change state
# Usage: osc-state <change> <action> [args]
# Output: JSON
#
# Actions:
#   get                              - Get current state
#   set-phase <PHASE>                - Set current phase
#   complete                         - Mark phase complete (normal advance)
#   transition <PHASE> <reason> [details] - Set explicit transition target
#   clear-transition                 - Clear transition field
#
# Transition reasons:
#   implementation_incorrect - Artifacts correct, code needs fixing
#   artifacts_modified       - Specs/design updated, re-implement needed
#   retry_requested          - Same phase, different approach

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/osc-common"

CHANGE_DIR="openspec/changes"

usage() {
    cat >&2 << 'EOF'
{"error":"usage","message":"Usage: osc-state <change> <action> [args]","actions":["get","set-phase <PHASE>","complete","transition <PHASE> <reason> [details]","clear-transition"],"transition_reasons":["implementation_incorrect","artifacts_modified","retry_requested"]}
EOF
    exit 1
}

json_escape() {
    local str="$1"
    str="${str//\\/\\\\}"
    str="${str//\"/\\\"}"
    str="${str//$'\n'/\\n}"
    str="${str//$'\r'/\\r}"
    str="${str//$'\t'/\\t}"
    echo "$str"
}

if [[ $# -lt 1 ]]; then
    usage
fi

CHANGE="$1"
ACTION="${2:-get}"
VALUE="${3:-}"

if ! CHANGE_DIR=$(osc_find_change_dir "$CHANGE"); then
    echo "{\"error\":\"change_not_found\",\"message\":\"Change directory does not exist\",\"change\":\"$CHANGE\"}" >&2
    exit 1
fi

STATE_FILE="$CHANGE_DIR/state.json"

case "$ACTION" in
    get)
        if [[ ! -f "$STATE_FILE" ]]; then
            echo "{\"error\":\"state_not_found\",\"message\":\"state.json does not exist\",\"path\":\"$STATE_FILE\"}" >&2
            exit 1
        fi

        PHASE=$(jq -r '.phase // "UNKNOWN"' "$STATE_FILE")
        ITERATION=$(jq -r '.iteration // 0' "$STATE_FILE")
        PHASE_COMPLETE=$(jq -r '.phase_complete // false' "$STATE_FILE")

        echo "{\"phase\":\"$PHASE\",\"iteration\":$ITERATION,\"phase_complete\":$PHASE_COMPLETE,\"change\":\"$CHANGE\"}"
        ;;

    set-phase)
        if [[ -z "$VALUE" ]]; then
            echo '{"error":"missing_value","message":"Phase value required for set-phase action"}' >&2
            exit 1
        fi

        if [[ ! -f "$STATE_FILE" ]]; then
            echo "{\"error\":\"state_not_found\",\"message\":\"state.json does not exist\",\"path\":\"$STATE_FILE\"}" >&2
            exit 1
        fi

        PREVIOUS_PHASE=$(jq -r '.phase // "UNKNOWN"' "$STATE_FILE")

        if ! osc_json_update "$STATE_FILE" '.phase = $phase' --arg phase "$VALUE"; then
            echo '{"error":"jq_failed","message":"Failed to update phase"}' >&2
            exit 1
        fi

        echo "{\"success\":true,\"phase\":\"$VALUE\",\"previous_phase\":\"$PREVIOUS_PHASE\"}"
        ;;

    complete)
        if [[ ! -f "$STATE_FILE" ]]; then
            echo "{\"error\":\"state_not_found\",\"message\":\"state.json does not exist\",\"path\":\"$STATE_FILE\"}" >&2
            exit 1
        fi

        if ! osc_json_update "$STATE_FILE" '.phase_complete = true'; then
            echo '{"error":"jq_failed","message":"Failed to mark complete"}' >&2
            exit 1
        fi

        echo '{"success":true,"phase_complete":true}'
        ;;

    transition)
        TARGET_PHASE="$VALUE"
        REASON="${4:-}"
        DETAILS="${5:-}"

        if [[ -z "$TARGET_PHASE" ]]; then
            echo '{"error":"missing_target","message":"Target phase required for transition action"}' >&2
            exit 1
        fi

        if [[ -z "$REASON" ]]; then
            echo '{"error":"missing_reason","message":"Reason required for transition action"}' >&2
            exit 1
        fi

        if [[ ! "$TARGET_PHASE" =~ ^PHASE[0-6]$ ]]; then
            echo "{\"error\":\"invalid_target\",\"message\":\"Invalid target phase: $TARGET_PHASE\",\"valid\":[\"PHASE0\",\"PHASE1\",\"PHASE2\",\"PHASE3\",\"PHASE4\",\"PHASE5\",\"PHASE6\"]}" >&2
            exit 1
        fi

        VALID_REASONS=("implementation_incorrect" "artifacts_modified" "retry_requested")
        REASON_VALID=false
        for r in "${VALID_REASONS[@]}"; do
            if [[ "$REASON" == "$r" ]]; then
                REASON_VALID=true
                break
            fi
        done

        if [[ "$REASON_VALID" == false ]]; then
            echo "{\"error\":\"invalid_reason\",\"message\":\"Invalid reason: $REASON\",\"valid\":[\"implementation_incorrect\",\"artifacts_modified\",\"retry_requested\"]}" >&2
            exit 1
        fi

        if [[ ! -f "$STATE_FILE" ]]; then
            echo "{\"error\":\"state_not_found\",\"message\":\"state.json does not exist\",\"path\":\"$STATE_FILE\"}" >&2
            exit 1
        fi

        TRANSITION_JSON=""
        if [[ -n "$DETAILS" ]]; then
            TRANSITION_JSON="{\"target\":\"$TARGET_PHASE\",\"reason\":\"$REASON\",\"details\":\"$(json_escape "$DETAILS")\"}"
        else
            TRANSITION_JSON="{\"target\":\"$TARGET_PHASE\",\"reason\":\"$REASON\"}"
        fi

        if ! osc_json_update "$STATE_FILE" '.phase_complete = true | .transition = '"$TRANSITION_JSON"; then
            echo '{"error":"jq_failed","message":"Failed to set transition"}' >&2
            exit 1
        fi

        if [[ -n "$DETAILS" ]]; then
            echo "{\"success\":true,\"transition\":{\"target\":\"$TARGET_PHASE\",\"reason\":\"$REASON\",\"details\":\"$(json_escape "$DETAILS")\"}}"
        else
            echo "{\"success\":true,\"transition\":{\"target\":\"$TARGET_PHASE\",\"reason\":\"$REASON\"}}"
        fi
        ;;

    clear-transition)
        if [[ ! -f "$STATE_FILE" ]]; then
            echo "{\"error\":\"state_not_found\",\"message\":\"state.json does not exist\",\"path\":\"$STATE_FILE\"}" >&2
            exit 1
        fi

        if ! osc_json_update "$STATE_FILE" 'del(.transition)'; then
            echo '{"error":"jq_failed","message":"Failed to clear transition"}' >&2
            exit 1
        fi

        echo '{"success":true,"transition_cleared":true}'
        ;;

    *)
        echo "{\"error\":\"unknown_action\",\"message\":\"Unknown action: $ACTION\",\"valid_actions\":[\"get\",\"set-phase\",\"complete\",\"transition\",\"clear-transition\"]}" >&2
        exit 1
        ;;
esac

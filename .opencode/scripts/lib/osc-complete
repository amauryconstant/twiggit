#!/usr/bin/env bash
# osc-complete - Completion status for OpenSpec changes
# Usage: osc-complete <change> <action> [args]
# Output: JSON

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/osc-common"

usage() {
    echo '{"error":"usage","message":"Usage: osc-complete <change> <action>","actions":["check","get","set [status] [with_blocker] [blocker_reason]"]}' >&2
    exit 1
}

json_escape() {
    local str="$1"
    str="${str//\\/\\\\}"
    str="${str//\"/\\\"}"
    str="${str//$'\n'/\\n}"
    str="${str//$'\r'/\\r}"
    str="${str//$'\t'/\\t}"
    echo "$str"
}

if [[ $# -lt 2 ]]; then
    usage
fi

CHANGE="$1"
ACTION="$2"
VALUE1="${3:-COMPLETE}"
VALUE2="${4:-false}"
VALUE3="${5:-}"

if ! CHANGE_DIR=$(osc_find_change_dir "$CHANGE"); then
    echo "{\"error\":\"change_not_found\",\"message\":\"Change directory does not exist\",\"change\":\"$CHANGE\"}" >&2
    exit 1
fi

COMPLETE_FILE="$CHANGE_DIR/complete.json"

check_complete() {
    if [[ ! -f "$COMPLETE_FILE" ]]; then
        echo '{"exists":false}'
        return 1
    fi

    if ! jq empty "$COMPLETE_FILE" 2>/dev/null; then
        echo '{"exists":false,"error":"invalid_json"}'
        return 1
    fi

    echo '{"exists":true}'
    return 0
}

get_complete() {
    if [[ ! -f "$COMPLETE_FILE" ]]; then
        echo '{"error":"complete_not_found","message":"complete.json does not exist"}' >&2
        exit 1
    fi

    if ! jq empty "$COMPLETE_FILE" 2>/dev/null; then
        echo '{"error":"invalid_json","message":"complete.json contains invalid JSON"}' >&2
        exit 1
    fi

    local status with_blocker blocker_reason
    status=$(jq -r '.status // "UNKNOWN"' "$COMPLETE_FILE")
    with_blocker=$(jq -r '.with_blocker // false' "$COMPLETE_FILE")
    blocker_reason=$(jq -r '.blocker_reason // ""' "$COMPLETE_FILE")

    if [[ -n "$blocker_reason" ]] && [[ "$with_blocker" == "true" ]]; then
        echo "{\"status\":\"$status\",\"with_blocker\":$with_blocker,\"blocker_reason\":\"$(json_escape "$blocker_reason")\"}"
    else
        echo "{\"status\":\"$status\",\"with_blocker\":$with_blocker}"
    fi
}

set_complete() {
    local status="$1"
    local with_blocker="$2"
    local blocker_reason="$3"

    local timestamp
    timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    if [[ "$with_blocker" == "true" ]] && [[ -n "$blocker_reason" ]]; then
        cat > "$COMPLETE_FILE" <<EOF
{
  "status": "$status",
  "with_blocker": true,
  "blocker_reason": "$(json_escape "$blocker_reason")",
  "timestamp": "$timestamp"
}
EOF
        echo "{\"status\":\"$status\",\"with_blocker\":true,\"blocker_reason\":\"$(json_escape "$blocker_reason")\"}"
    else
        cat > "$COMPLETE_FILE" <<EOF
{
  "status": "$status",
  "with_blocker": false,
  "timestamp": "$timestamp"
}
EOF
        echo "{\"status\":\"$status\",\"with_blocker\":false}"
    fi
}

case "$ACTION" in
    check)
        check_complete
        ;;

    get)
        get_complete
        ;;

    set)
        set_complete "$VALUE1" "$VALUE2" "$VALUE3"
        ;;

    *)
        echo "{\"error\":\"unknown_action\",\"message\":\"Unknown action: $ACTION\",\"valid_actions\":[\"check\",\"get\",\"set\"]}" >&2
        exit 1
        ;;
esac

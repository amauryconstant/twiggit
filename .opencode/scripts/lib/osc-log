#!/usr/bin/env bash
# osc-log - Manage OpenSpec decision log
# Usage: osc-log <change> [get|append]
# Input (append): JSON from stdin
# Output: JSON
# Writes: decision-log.json

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/osc-common"

CHANGE_DIR="openspec/changes"

usage() {
    echo '{"error":"usage","message":"Usage: osc-log <change> [get|append]","actions":["get (default)","append (reads JSON from stdin)"],"required_fields":["phase","iteration"],"optional_fields":["summary","issues","artifacts_modified","next_steps","decisions","errors"]}' >&2
    exit 1
}

if [[ $# -lt 1 ]]; then
    usage
fi

CHANGE="$1"
ACTION="${2:-get}"

if ! CHANGE_DIR=$(osc_find_change_dir "$CHANGE"); then
    echo "{\"error\":\"change_not_found\",\"message\":\"Change directory does not exist\",\"change\":\"$CHANGE\"}" >&2
    exit 1
fi

DECISION_JSON="$CHANGE_DIR/decision-log.json"

case "$ACTION" in
    get)
        if [[ ! -f "$DECISION_JSON" ]]; then
            echo "{\"count\":0,\"entries\":[]}"
            exit 0
        fi

        COUNT=$(jq 'length' "$DECISION_JSON" 2>/dev/null || echo "0")
        echo "{\"count\":$COUNT,\"entries\":$(cat "$DECISION_JSON")}"
        ;;

    append)
        if [[ -t 0 ]]; then
            echo '{"error":"no_input","message":"JSON input required on stdin for append action"}' >&2
            exit 1
        fi

        # Read JSON from stdin
        INPUT_JSON=$(cat)

        # Validate input is valid JSON
        if ! echo "$INPUT_JSON" | jq -e . &>/dev/null; then
            echo '{"error":"invalid_json","message":"Input is not valid JSON"}' >&2
            exit 1
        fi

        # Validate required fields
        PHASE=$(echo "$INPUT_JSON" | jq -r '.phase // empty')
        ITERATION=$(echo "$INPUT_JSON" | jq -r '.iteration // empty')

        if [[ -z "$PHASE" ]]; then
            echo '{"error":"missing_field","message":"phase field is required"}' >&2
            exit 1
        fi

        if [[ -z "$ITERATION" ]]; then
            echo '{"error":"missing_field","message":"iteration field is required"}' >&2
            exit 1
        fi

        # Generate timestamp
        TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ)

        # Determine next entry number using osc_json_length
        ENTRY_NUM=$(osc_json_length "$DECISION_JSON")
        ENTRY_NUM=$((ENTRY_NUM + 1))

        # Build JSON entry with timestamp and entry number
        JSON_ENTRY=$(echo "$INPUT_JSON" | jq \
            --arg ts "$TIMESTAMP" \
            --argjson entry "$ENTRY_NUM" \
            '. + {timestamp: $ts, entry: $entry}')

        # Append to decision log using osc_json_append
        if ! osc_json_append "$DECISION_JSON" "$JSON_ENTRY"; then
            echo '{"error":"jq_failed","message":"Failed to append to decision log"}' >&2
            exit 1
        fi

        echo "{\"success\":true,\"entry\":$ENTRY_NUM,\"phase\":\"$PHASE\",\"iteration\":$ITERATION,\"timestamp\":\"$TIMESTAMP\"}"
        ;;

    *)
        echo "{\"error\":\"unknown_action\",\"message\":\"Unknown action: $ACTION\",\"valid_actions\":[\"get\",\"append\"]}" >&2
        exit 1
        ;;
esac

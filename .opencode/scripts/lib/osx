#!/usr/bin/env python3
"""
osx - OpenSpec Extended change management tool

Usage:
    osx <domain> <action> [args] [options]

Domains:
    baseline    Baseline tracking (commit/branch)
    ctx         Aggregate context for a change
    git         Git status for change directory
    phase       Phase advancement management
    state       Phase and iteration state management
    iterations  Iteration history tracking
    log         Decision log management
    complete    Completion status tracking
    validate    Validation utilities

Output: JSON to stdout, errors to stderr
"""

import sys
import json
import argparse
import tempfile
from pathlib import Path
from datetime import datetime, timezone
from typing import Optional, Any, Dict, List

PHASES = ["PHASE0", "PHASE1", "PHASE2", "PHASE3", "PHASE4", "PHASE5", "PHASE6"]

PHASE_NAMES = {
    "PHASE0": "ARTIFACT REVIEW",
    "PHASE1": "IMPLEMENTATION",
    "PHASE2": "REVIEW",
    "PHASE3": "MAINTAIN DOCS",
    "PHASE4": "SYNC",
    "PHASE5": "SELF-REFLECTION",
    "PHASE6": "ARCHIVE",
}

PHASE_COMMANDS = {
    "PHASE0": "osx-phase0",
    "PHASE1": "osx-phase1",
    "PHASE2": "osx-phase2",
    "PHASE3": "osx-phase3",
    "PHASE4": "osx-phase4",
    "PHASE5": "osx-phase5",
    "PHASE6": "osx-phase6",
}

VALID_TRANSITION_REASONS = [
    "implementation_incorrect",
    "artifacts_modified",
    "retry_requested",
]

REQUIRED_SKILLS = [
    "osx-concepts",
    "osx-review-artifacts",
    "osx-modify-artifacts",
    "osc-apply-change",
    "osx-review-test-compliance",
    "osc-verify-change",
    "osx-maintain-ai-docs",
    "osc-sync-specs",
    "osc-archive-change",
]

SKILLS_DIR = Path(".opencode/skills")
COMMANDS_DIR = Path(".opencode/commands")


def get_version() -> str:
    """Get version from manifest.json."""
    script_dir = Path(__file__).parent
    manifest_path = script_dir.parent.parent / "manifest.json"

    if manifest_path.exists():
        try:
            manifest = json.loads(manifest_path.read_text())
            version = manifest.get("resources", {}).get("lib", {}).get("osx", {}).get("version")
            if version:
                return version
        except (json.JSONDecodeError, KeyError):
            pass

    return "unknown"


def error(code: str, message: str, **context) -> None:
    """Output error JSON to stderr and exit."""
    result = {"error": code, "message": message}
    result.update(context)
    print(json.dumps(result), file=sys.stderr)
    sys.exit(1)


def output(data: dict) -> None:
    """Output JSON to stdout."""
    print(json.dumps(data))


def get_timestamp() -> str:
    """Get current UTC timestamp in ISO format."""
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def find_change_dir(change: str) -> Path:
    """Find change directory (primary or archived)."""
    primary = Path(f"openspec/changes/{change}")
    if primary.is_dir():
        return primary

    archive_dir = Path("openspec/changes/archive")
    if not archive_dir.is_dir():
        error("change_not_found", "Change directory does not exist", change=change)

    for d in sorted(archive_dir.iterdir()):
        if d.is_dir() and d.name.endswith(f"-{change}"):
            return d

    error("change_not_found", "Change directory does not exist", change=change)


def read_json(path: Path) -> Any:
    """Read JSON file, return empty dict if not found."""
    if not path.exists():
        return {}
    try:
        return json.loads(path.read_text())
    except json.JSONDecodeError as e:
        error("invalid_json", f"Invalid JSON in {path}", path=str(path))


def write_json(path: Path, data: Any) -> None:
    """Write JSON file atomically."""
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile(
        mode="w", delete=False, dir=path.parent, suffix=".json"
    ) as f:
        json.dump(data, f, indent=2)
        f.flush()
        Path(f.name).replace(path)


def read_json_array(path: Path) -> List:
    """Read JSON array file, return empty list if not found or invalid."""
    if not path.exists():
        return []
    try:
        data = json.loads(path.read_text())
        if not isinstance(data, list):
            error("invalid_format", f"{path.name} is not a valid JSON array")
        return data
    except json.JSONDecodeError:
        error("invalid_json", f"Invalid JSON in {path}")


def append_to_json_array(path: Path, entry: Dict) -> int:
    """Append entry to JSON array file, return new count."""
    data = read_json_array(path)
    data.append(entry)
    write_json(path, data)
    return len(data)


def read_stdin_json() -> Optional[Dict]:
    """Read JSON from stdin if available."""
    import select

    if sys.stdin.isatty():
        return None

    if hasattr(select, "select"):
        try:
            has_data, _, _ = select.select([sys.stdin], [], [], 0)
            if not has_data:
                return None
        except (ValueError, OSError):
            return None

    try:
        content = sys.stdin.read().strip()
        if not content:
            return None
        return json.loads(content)
    except json.JSONDecodeError:
        error("invalid_json", "Input is not valid JSON")


def cmd_state_get(args):
    """Get current state."""
    change_dir = find_change_dir(args.change)
    state_file = change_dir / "state.json"

    if not state_file.exists():
        error("state_not_found", "state.json does not exist", path=str(state_file))

    state = read_json(state_file)
    output(
        {
            "phase": state.get("phase", "UNKNOWN"),
            "iteration": state.get("iteration", 0),
            "phase_complete": state.get("phase_complete", False),
            "change": args.change,
        }
    )


def cmd_state_set_phase(args):
    """Set current phase (and optionally iteration)."""
    if args.phase not in PHASES:
        error("invalid_phase", f"Invalid phase: {args.phase}", valid=PHASES)

    change_dir = find_change_dir(args.change)
    state_file = change_dir / "state.json"

    if not state_file.exists():
        error("state_not_found", "state.json does not exist")

    state = read_json(state_file)
    previous = state.get("phase", "UNKNOWN")
    state["phase"] = args.phase
    state["phase_name"] = PHASE_NAMES.get(args.phase, "UNKNOWN")
    if hasattr(args, "iteration") and args.iteration is not None:
        state["iteration"] = args.iteration
    state["last_updated"] = get_timestamp()
    write_json(state_file, state)

    output({"success": True, "phase": args.phase, "previous_phase": previous})


def cmd_state_complete(args):
    """Mark phase complete."""
    change_dir = find_change_dir(args.change)
    state_file = change_dir / "state.json"

    if not state_file.exists():
        error("state_not_found", "state.json does not exist")

    state = read_json(state_file)
    state["phase_complete"] = True
    state["last_updated"] = get_timestamp()
    write_json(state_file, state)

    output({"success": True, "phase_complete": True})


def cmd_state_transition(args):
    """Set explicit transition target."""
    if args.target not in PHASES:
        error(
            "invalid_target",
            f"Invalid target phase: {args.target}",
            valid=PHASES,
        )

    if args.reason not in VALID_TRANSITION_REASONS:
        error(
            "invalid_reason",
            f"Invalid reason: {args.reason}",
            valid=VALID_TRANSITION_REASONS,
        )

    change_dir = find_change_dir(args.change)
    state_file = change_dir / "state.json"

    if not state_file.exists():
        error("state_not_found", "state.json does not exist")

    state = read_json(state_file)
    state["phase_complete"] = True
    state["transition"] = {"target": args.target, "reason": args.reason}
    if args.details:
        state["transition"]["details"] = args.details
    state["last_updated"] = get_timestamp()
    write_json(state_file, state)

    result = {"success": True, "transition": {"target": args.target, "reason": args.reason}}
    if args.details:
        result["transition"]["details"] = args.details
    output(result)


def cmd_state_clear_transition(args):
    """Clear transition field."""
    change_dir = find_change_dir(args.change)
    state_file = change_dir / "state.json"

    if not state_file.exists():
        error("state_not_found", "state.json does not exist")

    state = read_json(state_file)
    state.pop("transition", None)
    state["last_updated"] = get_timestamp()
    write_json(state_file, state)

    output({"success": True, "transition_cleared": True})


def cmd_iterations_get(args):
    """Get iteration history."""
    change_dir = find_change_dir(args.change)
    iterations_file = change_dir / "iterations.json"

    if not iterations_file.exists():
        output({"count": 0, "iterations": []})
        return

    iterations = read_json_array(iterations_file)
    iteration_nums = [i.get("iteration") for i in iterations if "iteration" in i]
    output({"count": len(iterations), "iterations": iteration_nums})


def cmd_iterations_append(args):
    """Append iteration entry (from stdin or CLI args)."""
    change_dir = find_change_dir(args.change)
    iterations_file = change_dir / "iterations.json"

    stdin_data = read_stdin_json()
    if stdin_data is not None:
        entry = stdin_data
    else:
        if args.iteration is None or args.phase is None:
            error(
                "missing_field",
                "iteration and phase required (via --iteration and --phase or stdin)",
            )
        entry = {"iteration": args.iteration, "phase": args.phase}
        if args.summary:
            entry["summary"] = args.summary
        if args.status:
            entry["status"] = args.status
        if args.notes:
            entry["notes"] = args.notes
        if args.commit_hash:
            entry["commit_hash"] = args.commit_hash
        if args.issues:
            try:
                entry["issues"] = json.loads(args.issues)
            except json.JSONDecodeError:
                error("invalid_json", "issues must be valid JSON")
        if args.artifacts_modified:
            try:
                entry["artifacts_modified"] = json.loads(args.artifacts_modified)
            except json.JSONDecodeError:
                error("invalid_json", "artifacts_modified must be valid JSON")
        if args.decisions:
            try:
                entry["decisions"] = json.loads(args.decisions)
            except json.JSONDecodeError:
                error("invalid_json", "decisions must be valid JSON")
        if args.errors:
            try:
                entry["errors"] = json.loads(args.errors)
            except json.JSONDecodeError:
                error("invalid_json", "errors must be valid JSON")
        if args.extra:
            try:
                extra_data = json.loads(args.extra)
                if isinstance(extra_data, dict):
                    entry.update(extra_data)
            except json.JSONDecodeError:
                error("invalid_json", "extra must be valid JSON object")

    if "iteration" not in entry:
        error("missing_field", "iteration field is required")

    entry.setdefault("timestamp", get_timestamp())

    total = append_to_json_array(iterations_file, entry)
    output(
        {
            "success": True,
            "iteration": entry["iteration"],
            "total_count": total,
        }
    )



def cmd_git_get(args):
    """Get git status for change directory."""
    import subprocess

    change_dir = find_change_dir(args.change)

    result = {"modified": [], "added": [], "untracked": [], "clean": True}

    try:
        branch = subprocess.check_output(
            ["git", "branch", "--show-current"], stderr=subprocess.DEVNULL, text=True
        ).strip() or "unknown"
        result["branch"] = branch

        cmd = [
            "git", "status", "--porcelain",
            "--", str(change_dir)
        ]
        output_lines = subprocess.check_output(
            cmd, stderr=subprocess.DEVNULL, text=True
        ).strip().split("\n")

        for line in output_lines:
            if not line:
                continue
            status = line[:2]
            filepath = line[3:].strip()

            if status.startswith("M") or status[1] == "M":
                result["modified"].append(filepath)
                result["clean"] = False
            elif status.startswith("A") or status[1] == "A":
                result["added"].append(filepath)
                result["clean"] = False
            elif status.startswith("??"):
                result["untracked"].append(filepath)
                result["clean"] = False
            elif status.strip():
                result["modified"].append(filepath)
                result["clean"] = False

    except (subprocess.CalledProcessError, FileNotFoundError):
        result["branch"] = "unknown"

    output(result)


def cmd_ctx_get(args):
    """Get aggregated context for a change."""
    change_dir = find_change_dir(args.change)

    def check_artifact(path: Path, artifact_type: str) -> dict:
        if artifact_type == "directory":
            if path.is_dir():
                count = len(list(path.glob("*.md")))
                return {"exists": True, "count": count}
            return {"exists": False, "count": 0}
        else:
            if path.is_file():
                return {"exists": True, "size": path.stat().st_size}
            return {"exists": False, "size": 0}

    def get_state():
        state_file = change_dir / "state.json"
        if not state_file.exists():
            return {"phase": "UNKNOWN", "iteration": 0, "phase_complete": False}
        state = read_json(state_file)
        return {
            "phase": state.get("phase", "UNKNOWN"),
            "iteration": state.get("iteration", 0),
            "phase_complete": state.get("phase_complete", False),
        }

    def get_git():
        import subprocess
        result = {"modified": [], "added": [], "untracked": [], "clean": True}
        try:
            cmd = ["git", "status", "--porcelain", "--", str(change_dir)]
            output_lines = subprocess.check_output(
                cmd, stderr=subprocess.DEVNULL, text=True
            ).strip().split("\n")
            for line in output_lines:
                if not line:
                    continue
                status = line[:2]
                filepath = line[3:].strip()
                if status.startswith("M") or status[1] == "M":
                    result["modified"].append(filepath)
                    result["clean"] = False
                elif status.startswith("A") or status[1] == "A":
                    result["added"].append(filepath)
                    result["clean"] = False
                elif status.startswith("??"):
                    result["untracked"].append(filepath)
                    result["clean"] = False
                elif status.strip():
                    result["modified"].append(filepath)
                    result["clean"] = False
        except (subprocess.CalledProcessError, FileNotFoundError):
            pass
        return result

    proposal = check_artifact(change_dir / "proposal.md", "file")
    specs = check_artifact(change_dir / "specs", "directory")
    design = check_artifact(change_dir / "design.md", "file")
    tasks = check_artifact(change_dir / "tasks.md", "file")

    decision_log = read_json_array(change_dir / "decision-log.json")
    iterations = read_json_array(change_dir / "iterations.json")

    output({
        "change": args.change,
        "state": get_state(),
        "git": get_git(),
        "artifacts": {
            "proposal": proposal,
            "specs": specs,
            "design": design,
            "tasks": tasks,
        },
        "history": {
            "decision_log_entries": len(decision_log),
            "iterations_recorded": len(iterations),
        },
    })


def cmd_instructions(args):
    """Proxy to openspec instructions command."""
    import subprocess

    cmd_args = ["openspec", "instructions", args.artifact]
    if args.change:
        cmd_args.extend(["--change", args.change])
    if getattr(args, "json", False):
        cmd_args.append("--json")

    try:
        result = subprocess.run(cmd_args, capture_output=True, text=True)
        print(result.stdout, end="")
        if result.returncode != 0:
            print(result.stderr, file=sys.stderr, end="")
            sys.exit(result.returncode)
    except FileNotFoundError:
        error("cli_not_found", "openspec CLI not found in PATH")


def cmd_baseline_record(args):
    """Record baseline (current commit/branch)."""
    import subprocess

    try:
        subprocess.check_output(
            ["git", "rev-parse", "--is-inside-work-tree"],
            stderr=subprocess.DEVNULL, text=True
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        error("not_git_repo", "Current directory is not a git repository")

    try:
        commit = subprocess.check_output(
            ["git", "rev-parse", "HEAD"], stderr=subprocess.DEVNULL, text=True
        ).strip()
        branch = subprocess.check_output(
            ["git", "branch", "--show-current"], stderr=subprocess.DEVNULL, text=True
        ).strip() or "unknown"
    except (subprocess.CalledProcessError, FileNotFoundError):
        error("git_error", "Failed to get git info")

    timestamp = get_timestamp()

    baseline_file = Path(".openspec-baseline.json")
    data = {
        "commit": commit,
        "branch": branch,
        "timestamp": timestamp,
    }
    write_json(baseline_file, data)
    output(data)


def cmd_baseline_get(args):
    """Get baseline content."""
    baseline_file = Path(".openspec-baseline.json")

    if not baseline_file.exists():
        error("baseline_not_found", ".openspec-baseline.json does not exist")

    try:
        data = json.loads(baseline_file.read_text())
    except json.JSONDecodeError:
        error("invalid_json", ".openspec-baseline.json contains invalid JSON")

    output(data)


def get_next_phase(current: str) -> str:
    """Get next phase in sequence."""
    phase_order = {
        "PHASE0": "PHASE1",
        "PHASE1": "PHASE2",
        "PHASE2": "PHASE3",
        "PHASE3": "PHASE4",
        "PHASE4": "PHASE5",
        "PHASE5": "PHASE6",
        "PHASE6": "COMPLETE",
        "COMPLETE": "COMPLETE",
    }
    return phase_order.get(current, "COMPLETE")


def cmd_phase_current(args):
    """Get current phase info."""
    change_dir = find_change_dir(args.change)
    state_file = change_dir / "state.json"

    if "archive" in str(change_dir) and not state_file.exists():
        error("archived", "Change is archived, no active state")

    if not state_file.exists():
        timestamp = get_timestamp()
        state = {
            "phase": "PHASE0",
            "phase_name": PHASE_NAMES.get("PHASE0", "UNKNOWN"),
            "iteration": 1,
            "phase_complete": False,
            "phase_iterations": {},
            "started_at": timestamp,
            "last_updated": timestamp,
        }
        write_json(state_file, state)
    else:
        state = read_json(state_file)

    phase = state.get("phase", "UNKNOWN")
    iteration = state.get("iteration", 0)
    next_phase = get_next_phase(phase)

    output({"phase": phase, "next": next_phase, "iteration": iteration})


def cmd_phase_next(args):
    """Get next phase name."""
    change_dir = find_change_dir(args.change)
    state_file = change_dir / "state.json"

    if not state_file.exists():
        timestamp = get_timestamp()
        state = {
            "phase": "PHASE0",
            "phase_name": PHASE_NAMES.get("PHASE0", "UNKNOWN"),
            "iteration": 1,
            "phase_complete": False,
            "phase_iterations": {},
            "started_at": timestamp,
            "last_updated": timestamp,
        }
        write_json(state_file, state)
    else:
        state = read_json(state_file)

    current = state.get("phase", "UNKNOWN")
    if not current:
        error("invalid_state", "state.json missing phase field")

    next_phase = get_next_phase(current)
    output({"next": next_phase})


def cmd_phase_advance(args):
    """Advance to next phase."""
    change_dir = find_change_dir(args.change)
    state_file = change_dir / "state.json"

    if not state_file.exists():
        timestamp = get_timestamp()
        state = {
            "phase": "PHASE0",
            "phase_name": PHASE_NAMES.get("PHASE0", "UNKNOWN"),
            "iteration": 1,
            "phase_complete": False,
            "phase_iterations": {},
            "started_at": timestamp,
            "last_updated": timestamp,
        }
        write_json(state_file, state)
    else:
        state = read_json(state_file)

    current_phase = state.get("phase", "UNKNOWN")
    if not current_phase:
        error("invalid_state", "state.json missing phase field")

    next_phase = get_next_phase(current_phase)
    timestamp = get_timestamp()

    state["phase"] = next_phase
    state["phase_name"] = PHASE_NAMES.get(next_phase, "UNKNOWN")
    state["iteration"] = 1
    state["phase_complete"] = False
    state["last_updated"] = timestamp
    write_json(state_file, state)

    next_next = get_next_phase(next_phase)
    output({
        "phase": next_phase,
        "previous": current_phase,
        "next": next_next,
        "iteration": 1,
    })



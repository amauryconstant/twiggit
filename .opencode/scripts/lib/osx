def cmd_complete_check(args):
    """Check if complete.json exists."""
    change_dir = find_change_dir(args.change)
    complete_file = change_dir / "complete.json"

    if not complete_file.exists():
        output({"exists": False})
        sys.exit(1)

    try:
        json.loads(complete_file.read_text())
        output({"exists": True})
    except json.JSONDecodeError:
        output({"exists": False, "error": "invalid_json"})
        sys.exit(1)


def cmd_complete_get(args):
    """Get completion status."""
    change_dir = find_change_dir(args.change)
    complete_file = change_dir / "complete.json"

    if not complete_file.exists():
        error("complete_not_found", "complete.json does not exist")

    try:
        data = json.loads(complete_file.read_text())
    except json.JSONDecodeError:
        error("invalid_json", "complete.json contains invalid JSON")

    result = {
        "status": data.get("status", "UNKNOWN"),
        "with_blocker": data.get("with_blocker", False),
    }
    if data.get("blocker_reason"):
        result["blocker_reason"] = data["blocker_reason"]

    output(result)


def cmd_complete_set(args):
    """Set completion status."""
    change_dir = find_change_dir(args.change)
    complete_file = change_dir / "complete.json"

    timestamp = get_timestamp()

    if args.status == "BLOCKED" and args.blocker_reason:
        data = {
            "status": args.status,
            "with_blocker": True,
            "blocker_reason": args.blocker_reason,
            "timestamp": timestamp,
        }
        write_json(complete_file, data)
        output(
            {
                "status": args.status,
                "with_blocker": True,
                "blocker_reason": args.blocker_reason,
            }
        )
    else:
        data = {
            "status": args.status,
            "with_blocker": False,
            "timestamp": timestamp,
        }
        write_json(complete_file, data)
        output({"status": args.status, "with_blocker": False})


def cmd_validate_json(args):
    """Validate JSON file."""
    file_path = Path(args.file)

    if not file_path.exists():
        output(
            {
                "valid": False,
                "errors": [{"check": "json", "message": f"File not found: {args.file}"}],
            }
        )
        sys.exit(1)

    try:
        json.loads(file_path.read_text())
        output({"valid": True})
    except json.JSONDecodeError:
        output(
            {
                "valid": False,
                "errors": [
                    {"check": "json", "message": f"Invalid JSON in file: {args.file}"}
                ],
            }
        )
        sys.exit(1)


def cmd_validate_skills(args):
    """Validate required skills exist."""
    errors = []

    for skill in REQUIRED_SKILLS:
        skill_path = SKILLS_DIR / skill / "SKILL.md"
        if not skill_path.exists():
            errors.append({"check": "skills", "message": f"Missing skill: {skill}"})

    if errors:
        output({"valid": False, "errors": errors})
        sys.exit(1)

    output({"valid": True})


def cmd_validate_commands(args):
    """Validate required commands exist."""
    errors = []

    for phase in PHASES:
        cmd_name = PHASE_COMMANDS.get(phase)
        if cmd_name:
            cmd_path = COMMANDS_DIR / f"{cmd_name}.md"
            if not cmd_path.exists():
                errors.append(
                    {"check": "commands", "message": f"Missing command: {cmd_name}"}
                )

    if errors:
        output({"valid": False, "errors": errors})
        sys.exit(1)

    output({"valid": True})


def cmd_validate_change_dir(args):
    """Validate change directory structure."""
    change_path = Path(f"openspec/changes/{args.change}")
    errors = []

    if not change_path.is_dir():
        output(
            {
                "valid": False,
                "errors": [
                    {
                        "check": "change-dir",
                        "message": f"Change directory not found: {change_path}",
                    }
                ],
            }
        )
        sys.exit(1)

    required_files = ["tasks.md", "proposal.md", "design.md"]
    for file in required_files:
        if not (change_path / file).exists():
            errors.append(
                {"check": "change-dir", "message": f"Missing required file: {file}"}
            )

    specs_dir = change_path / "specs"
    if not specs_dir.is_dir() or not list(specs_dir.rglob("*.md")):
        errors.append(
            {"check": "change-dir", "message": "No spec files found in specs/"}
        )

    if errors:
        output({"valid": False, "errors": errors})
        sys.exit(1)

    output({"valid": True})


def cmd_validate_archive(args):
    """Validate change is archived."""
    archive_dir = Path("openspec/changes/archive")
    archives = []

    if archive_dir.is_dir():
        for d in archive_dir.iterdir():
            if d.is_dir() and d.name.endswith(f"-{args.change}"):
                archives.append(d)

    if len(archives) == 0:
        output(
            {
                "valid": False,
                "errors": [{"check": "archive", "message": "Change not archived"}],
            }
        )
        sys.exit(1)

    if len(archives) > 1:
        output(
            {
                "valid": False,
                "errors": [
                    {
                        "check": "archive",
                        "message": f"Multiple archives found for change: {len(archives)}",
                    }
                ],
            }
        )
        sys.exit(1)

    output({"valid": True, "archive": str(archives[0])})



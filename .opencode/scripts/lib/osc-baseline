#!/usr/bin/env bash
# osc-baseline - Baseline tracking for OpenSpec changes
# Usage: osc-baseline <action>
# Output: JSON

set -euo pipefail

BASELINE_FILE=".openspec-baseline.json"

usage() {
    echo '{"error":"usage","message":"Usage: osc-baseline <action>","actions":["record","get"]}' >&2
    exit 1
}

json_escape() {
    local str="$1"
    str="${str//\\/\\\\}"
    str="${str//\"/\\\"}"
    str="${str//$'\n'/\\n}"
    str="${str//$'\r'/\\r}"
    str="${str//$'\t'/\\t}"
    echo "$str"
}

record_baseline() {
    if ! git rev-parse --is-inside-work-tree &>/dev/null; then
        echo '{"error":"not_git_repo","message":"Current directory is not a git repository"}' >&2
        exit 1
    fi

    local commit branch timestamp
    commit=$(git rev-parse HEAD)
    branch=$(git branch --show-current 2>/dev/null || echo "unknown")
    timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    cat > "$BASELINE_FILE" <<EOF
{
  "commit": "$commit",
  "branch": "$branch",
  "timestamp": "$timestamp"
}
EOF

    echo "{\"commit\":\"$commit\",\"branch\":\"$branch\",\"timestamp\":\"$timestamp\"}"
}

get_baseline() {
    if [[ ! -f "$BASELINE_FILE" ]]; then
        echo '{"error":"baseline_not_found","message":".openspec-baseline.json does not exist"}' >&2
        exit 1
    fi

    if ! jq empty "$BASELINE_FILE" 2>/dev/null; then
        echo '{"error":"invalid_json","message":".openspec-baseline.json contains invalid JSON"}' >&2
        exit 1
    fi

    cat "$BASELINE_FILE"
}

if [[ $# -lt 1 ]]; then
    usage
fi

ACTION="$1"

case "$ACTION" in
    record)
        record_baseline
        ;;

    get)
        get_baseline
        ;;

    *)
        echo "{\"error\":\"unknown_action\",\"message\":\"Unknown action: $ACTION\",\"valid_actions\":[\"record\",\"get\"]}" >&2
        exit 1
        ;;
esac

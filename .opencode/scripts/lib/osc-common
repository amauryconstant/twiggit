#!/usr/bin/env bash
# osc-common - Shared functions for OpenSpec lib scripts
# Usage: source this file from other osc-* scripts
#
# Functions provided:
#   osc_json_length  - Safely get JSON array length
#   osc_json_update  - Safely update JSON file with jq
#   osc_json_append  - Safely append entry to JSON array file
#   osc_find_change_dir - Find change directory (primary or archived)
#   osc_get_phase_name - Get canonical phase name for iterations.json
#   osc_get_phase_display_name - Get display name for UI/logging

set -euo pipefail

if [[ -z "${SCRIPT_DIR:-}" ]]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fi

osc_get_phase_name() {
    local phase="$1"
    case "$phase" in
        PHASE0) echo "ARTIFACT_REVIEW" ;;
        PHASE1) echo "IMPLEMENTATION" ;;
        PHASE2) echo "REVIEW" ;;
        PHASE3) echo "MAINTAIN_DOCS" ;;
        PHASE4) echo "SYNC" ;;
        PHASE5) echo "SELF_REFLECTION" ;;
        PHASE6) echo "ARCHIVE" ;;
        *) echo "UNKNOWN" ;;
    esac
}

osc_get_phase_display_name() {
    local phase="$1"
    case "$phase" in
        PHASE0) echo "ARTIFACT REVIEW" ;;
        PHASE1) echo "IMPLEMENTATION" ;;
        PHASE2) echo "REVIEW" ;;
        PHASE3) echo "MAINTAIN DOCS" ;;
        PHASE4) echo "SYNC" ;;
        PHASE5) echo "SELF-REFLECTION" ;;
        PHASE6) echo "ARCHIVE" ;;
        *) echo "UNKNOWN" ;;
    esac
}

osc_json_length() {
    local file="$1"

    if [[ ! -f "$file" ]]; then
        echo "0"
        return 0
    fi

    # Check if file contains a valid JSON array
    if ! jq -e 'type == "array"' "$file" &>/dev/null; then
        echo "0"
        return 0
    fi

    local result
    result=$(jq 'length' "$file" 2>/dev/null || echo "0")

    if ! [[ "$result" =~ ^[0-9]+$ ]]; then
        echo "0"
        return 0
    fi

    echo "$result"
}

osc_json_update() {
    local file="$1"
    local jq_filter="$2"
    shift 2

    local tmp_file="${file}.tmp"

    if ! jq "$@" "$jq_filter" "$file" > "$tmp_file" 2>/dev/null; then
        rm -f "$tmp_file"
        return 1
    fi

    mv "$tmp_file" "$file"
    return 0
}

osc_json_append() {
    local file="$1"
    local entry="$2"
    local tmp_file="${file}.tmp"

    if [[ ! -f "$file" ]]; then
        if ! echo "[$entry]" > "$file" 2>/dev/null; then
            return 1
        fi
        return 0
    fi

    if ! jq ". + [$entry]" "$file" > "$tmp_file" 2>/dev/null; then
        rm -f "$tmp_file"
        return 1
    fi

    mv "$tmp_file" "$file"
    return 0
}

osc_find_change_dir() {
    local change="$1"
    local primary="openspec/changes/$change"

    if [[ -d "$primary" ]]; then
        echo "$primary"
        return 0
    fi

    local archive_dir="openspec/changes/archive"
    if [[ ! -d "$archive_dir" ]]; then
        return 1
    fi

    local archive_match
    archive_match=$(find "$archive_dir" -maxdepth 1 -type d -name "*-$change" 2>/dev/null | head -1)

    if [[ -n "$archive_match" ]]; then
        echo "$archive_match"
        return 0
    fi

    return 1
}

# Capture command output, always return 0 (for optional values)
# Use this when you need the output of a command that might fail,
# but failure is a valid case (not an error).
#
# Usage: capture_optional result_var command [args...]
# Example: capture_optional target check_transition
#
# The result variable will be set to the command's stdout (or empty on failure)
capture_optional() {
    local -n _capture_ref=$1
    shift
    _capture_ref=$("$@" 2>/dev/null) || true
}

#!/usr/bin/env bash
# osc-git - Git status for OpenSpec changes
# Usage: osc-git [change]
# Output: JSON

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/osc-common"

json_array() {
    local items=("$@")
    if [[ ${#items[@]} -eq 0 ]]; then
        echo "[]"
        return
    fi
    local result="["
    local first=true
    for item in "${items[@]}"; do
        if [[ "$first" == "true" ]]; then
            first=false
        else
            result+=","
        fi
        result+="\"$(json_escape "$item")\""
    done
    result+="]"
    echo "$result"
}

json_escape() {
    local str="$1"
    str="${str//\\/\\\\}"
    str="${str//\"/\\\"}"
    str="${str//$'\n'/\\n}"
    str="${str//$'\r'/\\r}"
    str="${str//$'\t'/\\t}"
    echo "$str"
}

# Check if we're in a git repo
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo '{"error":"not_git_repo","message":"Current directory is not a git repository"}' >&2
    exit 1
fi

CHANGE="${1:-}"

if [[ -z "$CHANGE" ]]; then
    # General git status
    MODIFIED=()
    ADDED=()
    UNTRACKED=()

    while IFS= read -r line; do
        status="${line:0:2}"
        file="${line:3}"

        case "$status" in
            " M"|"M "|\?\?|M"  "|" M"|"A "|" A")
                if [[ "$status" == "??" ]]; then
                    UNTRACKED+=("$file")
                elif [[ "$status" =~ [M] ]]; then
                    MODIFIED+=("$file")
                elif [[ "$status" =~ [A] ]]; then
                    ADDED+=("$file")
                fi
                ;;
        esac
    done < <(git status --porcelain 2>/dev/null || echo "")

    BRANCH=$(git branch --show-current 2>/dev/null || echo "unknown")
    CLEAN=$([[ ${#MODIFIED[@]} -eq 0 && ${#ADDED[@]} -eq 0 && ${#UNTRACKED[@]} -eq 0 ]] && echo "true" || echo "false")

    MODIFIED_JSON=$(json_array "${MODIFIED[@]}")
    ADDED_JSON=$(json_array "${ADDED[@]}")
    UNTRACKED_JSON=$(json_array "${UNTRACKED[@]}")

    echo "{\"modified\":${#MODIFIED[@]},\"added\":${#ADDED[@]},\"untracked\":${#UNTRACKED[@]},\"clean\":$CLEAN,\"branch\":\"$BRANCH\",\"files\":{\"modified\":$MODIFIED_JSON,\"added\":$ADDED_JSON,\"untracked\":$UNTRACKED_JSON}}"
else
    # Validate change exists (supports archive)
    if ! CHANGE_DIR=$(osc_find_change_dir "$CHANGE"); then
        echo "{\"error\":\"change_not_found\",\"message\":\"Change directory does not exist\",\"change\":\"$CHANGE\"}" >&2
        exit 1
    fi

    # Filtered to change directory
    MODIFIED=()
    ADDED=()
    UNTRACKED=()

    while IFS= read -r line; do
        status="${line:0:2}"
        file="${line:3}"

        if [[ "$file" == "$CHANGE_DIR/"* || "$file" == "$CHANGE_DIR" ]]; then
            if [[ "$status" == "??" ]]; then
                UNTRACKED+=("$file")
            elif [[ "$status" =~ [M] ]]; then
                MODIFIED+=("$file")
            elif [[ "$status" =~ [A] ]]; then
                ADDED+=("$file")
            fi
        fi
    done < <(git status --porcelain 2>/dev/null || echo "")

    CLEAN=$([[ ${#MODIFIED[@]} -eq 0 && ${#ADDED[@]} -eq 0 && ${#UNTRACKED[@]} -eq 0 ]] && echo "true" || echo "false")

    MODIFIED_JSON=$(json_array "${MODIFIED[@]}")
    ADDED_JSON=$(json_array "${ADDED[@]}")
    UNTRACKED_JSON=$(json_array "${UNTRACKED[@]}")

    echo "{\"change\":\"$CHANGE\",\"modified\":$MODIFIED_JSON,\"added\":$ADDED_JSON,\"untracked\":$UNTRACKED_JSON,\"clean\":$CLEAN}"
fi

#!/usr/bin/env bash
# osc-iterations - Manage OpenSpec iteration history
# Usage: osc-iterations <change> [get|append]
# Input (append): JSON from stdin
# Output: JSON

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/osc-common"

CHANGE_DIR="openspec/changes"

usage() {
    echo '{"error":"usage","message":"Usage: osc-iterations <change> [get|append]","actions":["get (default)","append (reads JSON from stdin)"]}' >&2
    exit 1
}

if [[ $# -lt 1 ]]; then
    usage
fi

CHANGE="$1"
ACTION="${2:-get}"

if ! CHANGE_DIR=$(osc_find_change_dir "$CHANGE"); then
    echo "{\"error\":\"change_not_found\",\"message\":\"Change directory does not exist\",\"change\":\"$CHANGE\"}" >&2
    exit 1
fi

ITERATIONS_FILE="$CHANGE_DIR/iterations.json"

case "$ACTION" in
    get)
        if [[ ! -f "$ITERATIONS_FILE" ]]; then
            echo "{\"count\":0,\"iterations\":[]}"
            exit 0
        fi

        # Validate it's an array
        if ! jq -e 'type == "array"' "$ITERATIONS_FILE" &>/dev/null; then
            echo "{\"error\":\"invalid_format\",\"message\":\"iterations.json is not a valid JSON array\",\"path\":\"$ITERATIONS_FILE\"}" >&2
            exit 1
        fi

        COUNT=$(jq 'length' "$ITERATIONS_FILE")
        ITERATION_NUMS=$(jq '[.[].iteration // empty]' "$ITERATIONS_FILE")

        echo "{\"count\":$COUNT,\"iterations\":$ITERATION_NUMS}"
        ;;

    append)
        if [[ -t 0 ]]; then
            echo '{"error":"no_input","message":"JSON input required on stdin for append action"}' >&2
            exit 1
        fi

        # Read JSON from stdin
        INPUT_JSON=$(cat)

        # Validate input is valid JSON
        if ! echo "$INPUT_JSON" | jq -e . &>/dev/null; then
            echo '{"error":"invalid_json","message":"Input is not valid JSON"}' >&2
            exit 1
        fi

        # Validate required fields
        ITER_NUM=$(echo "$INPUT_JSON" | jq -r '.iteration // empty')
        if [[ -z "$ITER_NUM" ]]; then
            echo '{"error":"missing_field","message":"iteration field is required"}' >&2
            exit 1
        fi

        # Add timestamp if not present
        INPUT_JSON=$(echo "$INPUT_JSON" | jq --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" '.timestamp //= $ts')

        # Append to iterations file using osc_json_append
        if ! osc_json_append "$ITERATIONS_FILE" "$INPUT_JSON"; then
            echo '{"error":"jq_failed","message":"Failed to append to iterations"}' >&2
            exit 1
        fi

        TOTAL=$(osc_json_length "$ITERATIONS_FILE")

        echo "{\"success\":true,\"iteration\":$ITER_NUM,\"total_count\":$TOTAL}"
        ;;

    *)
        echo "{\"error\":\"unknown_action\",\"message\":\"Unknown action: $ACTION\",\"valid_actions\":[\"get\",\"append\"]}" >&2
        exit 1
        ;;
esac
